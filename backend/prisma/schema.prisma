generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  role       Role     @default(operator)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  
  notes      Note[]   @relation("NoteCreator")
}

enum Role {
  admin
  operator
}

model Person {
  id         String   @id @default(uuid())
  name       String
  created_at DateTime @default(now())
  
  notes_as_buyer     Note[] @relation("NoteBuyer")
  notes_as_requester Note[] @relation("NoteRequester")
}

model Category {
  id         String   @id @default(uuid())
  name       String
  code       String   @unique
  type       String   @default("COA Project")
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  
  notes      Note[]
}

model Note {
  id           String    @id @default(uuid())
  date         DateTime
  buyer_id     String
  requester_id String
  category_id  String
  total        Decimal   @db.Decimal(12, 2)
  image_url    String?
  created_by   String
  
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime? // Soft delete implementation
  
  // Relations
  buyer        Person    @relation("NoteBuyer", fields: [buyer_id], references: [id])
  requester    Person    @relation("NoteRequester", fields: [requester_id], references: [id])
  category     Category  @relation(fields: [category_id], references: [id])
  user         User      @relation("NoteCreator", fields: [created_by], references: [id])
  
  items        NoteItem[]
  versions     NoteVersion[]
}

model NoteItem {
  id        String  @id @default(uuid())
  note_id   String
  item_name String
  qty       Int
  price     Decimal @db.Decimal(12, 2)
  subtotal  Decimal @db.Decimal(12, 2)
  
  note      Note    @relation(fields: [note_id], references: [id], onDelete: Cascade)
}

model NoteVersion {
  id             String   @id @default(uuid())
  note_id        String
  version_number Int
  snapshot       Json     @db.JsonB
  updated_by     String
  updated_at     DateTime @default(now())
  
  note           Note     @relation(fields: [note_id], references: [id], onDelete: Cascade)
}

model Notification {
  id         String   @id @default(uuid())
  message    String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
}
